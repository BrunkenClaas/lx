    add user profile update endpoint

    Allow authenticated users to update their display name and avatar URL
    via a new PATCH /users/{id}/profile endpoint.

diff --git a/src/api/users.rs b/src/api/users.rs
index 1234567..abcdefg 100644
--- a/src/api/users.rs
+++ b/src/api/users.rs
@@ -42,6 +42,38 @@ pub fn get_user(id: Uuid) -> Result<User, ApiError> {
     db::find_user(id).map_err(ApiError::from)
 }

+/// PATCH /users/{id}/profile
+///
+/// Update the authenticated user's display name and/or avatar URL.
+/// Only the owner of the account may update their own profile.
+pub fn update_profile(
+    id: Uuid,
+    caller: &AuthenticatedUser,
+    req: UpdateProfileRequest,
+) -> Result<User, ApiError> {
+    if caller.id != id {
+        return Err(ApiError::Forbidden("cannot update another user's profile".to_string()));
+    }
+    if let Some(ref name) = req.display_name {
+        if name.trim().is_empty() || name.len() > 64 {
+            return Err(ApiError::BadRequest("display_name must be 1–64 chars".to_string()));
+        }
+    }
+    if let Some(ref url) = req.avatar_url {
+        if !url.starts_with("https://") {
+            return Err(ApiError::BadRequest("avatar_url must use HTTPS".to_string()));
+        }
+    }
+    db::update_user_profile(id, req).map_err(ApiError::from)
+}
+
+#[derive(Debug, serde::Deserialize)]
+pub struct UpdateProfileRequest {
+    pub display_name: Option<String>,
+    pub avatar_url:   Option<String>,
+}

