+
+#[test]
+fn test_update_profile_success() {
+    let user = create_test_user();
+    let resp = test_patch(
+        &format!("/users/{}/profile", user.id),
+        json!({"display_name": "New Name"}),
+        &user.token,
+    );
+    assert_eq!(resp.status(), 200);
+    assert_eq!(resp.json::<User>().display_name, "New Name");
+}
+
+#[test]
+fn test_update_profile_forbidden() {
+    let user_a = create_test_user();
+    let user_b = create_test_user();
+    let resp = test_patch(
+        &format!("/users/{}/profile", user_b.id),
+        json!({"display_name": "Hacker"}),
+        &user_a.token,
+    );
+    assert_eq!(resp.status(), 403);
+}
