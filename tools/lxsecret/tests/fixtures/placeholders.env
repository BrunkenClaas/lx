# classify them as "placeholder" rather than "real".

# Documentation-style placeholders
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# README-style examples
GITHUB_TOKEN=ghp_your_github_token_here_replace_me

# Template markers
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY

# Obvious test/example values
OPENAI_API_KEY=sk-test_example_key_for_documentation
