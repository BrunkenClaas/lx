diff --git a/src/cache.rs b/src/cache.rs
index 1a2b3c4..5d6e7f8 100644
--- a/src/cache.rs
+++ b/src/cache.rs
@@ -8,6 +8,20 @@ use std::collections::HashMap;
 pub struct Cache {
     inner: HashMap<String, Vec<u8>>,
+    max_entries: usize,
 }

 impl Cache {
     pub fn new() -> Self {
-        Cache { inner: HashMap::new() }
+        Cache { inner: HashMap::new(), max_entries: 1024 }
+    }
+
+    pub fn with_capacity(max_entries: usize) -> Self {
+        Cache { inner: HashMap::new(), max_entries }
+    }
+
+    pub fn insert(&mut self, key: String, value: Vec<u8>) {
+        if self.inner.len() >= self.max_entries {
+            // Evict the first entry when the cache is full.
+            if let Some(k) = self.inner.keys().next().cloned() {
+                self.inner.remove(&k);
+            }
+        }
+        self.inner.insert(key, value);
     }
 }
