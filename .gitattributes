# Default: treat as text, normalize to LF
* text=auto eol=lf

# Explicitly text (LF)
*.rs        text eol=lf
*.toml      text eol=lf
*.lock      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf
*.fish      text eol=lf
*.ps1       text eol=lf
*.bat       text eol=crlf
*.gitignore text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.exe       binary
*.dll       binary
*.so        binary
*.a         binary
*.rlib      binary
